<!DOCTYPE html>
<html>
<head>
    <title>Recipe Details</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            height: 100vh;

            /* 🌄 BACKGROUND IMAGE */
            background: url('https://images.unsplash.com/photo-1504754524776-8f4f37790ca0') no-repeat center center/cover;
            position: relative;
        }

        /* 🔵 BLUR OVERLAY */
        body::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            backdrop-filter: blur(10px);
            background: rgba(0,0,0,0.4);
            z-index: 0;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100%;
            position: relative;
            z-index: 1;
        }

        /* ✨ CARD */
        .card {
            background: rgba(255, 255, 255, 0.9); /* more white */
            padding: 30px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            width: 900px;
            color: black; /* ✅ TEXT BLACK */
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
            color: black;
        }

        .row {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        /* 📦 SEPARATE BOXES */
        .section {
            flex: 1;
            min-width: 250px;
            background: rgba(255,255,255,0.7);
            padding: 15px;
            border-radius: 10px;
        }

        .section h3 {
            border-bottom: 2px solid #ccc;
            padding-bottom: 5px;
            color: black;
        }

        .section p {
            line-height: 1.6;
            color: black;
        }

        img {
            width: 100%;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.4);
        }

        .back {
            display: block;
            text-align: center;
            margin-top: 20px;
            text-decoration: none;
            color: black;
            font-weight: bold;
        }

        .back:hover {
            text-decoration: underline;
        }

    </style>
</head>

<body>

<div class="container">

<div class="card">

<h2> <%= recipe.title %></h2>

<div class="row">

    <!-- 🥗 INGREDIENTS -->
    <div class="section">
        <h3>Ingredients</h3>
        <p><%= recipe.ingredients %></p>
    </div>

    <!-- 🔥 PROCESS -->
    <div class="section">
        <h3>Process</h3>
        <p><%= recipe.instructions %></p>
    </div>

    <!-- 🖼 IMAGE -->
    <div class="section">
        <h3>Image</h3>
        <img src="/<%= recipe.imagePath %>" />
    </div>

</div>

<a href="/search" class="back"> Back to Search</a>

</div>

</div>

</body>
</html>